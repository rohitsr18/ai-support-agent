# Copy this file to .env and fill in real values

# LLM Provider: "auto", "ollama", "groq", "openai", or "gemini"
# "auto" tries providers in order until one works (default)
LLM_PROVIDER=auto

# --- Ollama (Local, FREE) ---
# Best for development. Install: https://ollama.ai
# Run: ollama run llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Groq (Cloud, FREE tier) ---
# Get free API key: https://console.groq.com
# Models: llama-3.1-8b-instant, mixtral-8x7b-32768, gemma2-9b-it
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# --- OpenAI (Cloud, PAID) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --- Gemini (Cloud, PAID) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
